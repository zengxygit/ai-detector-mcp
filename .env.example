# 环境配置

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_RELOAD=true

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=./logs

# 模型配置
MODELS_DIR=./models
ENABLE_GPU=true
DEVICE=auto

# 会话配置
SESSION_TIMEOUT=3600
MAX_FILE_SIZE=536870912  # 500MB

# 图像配置
IMAGE_MAX_SIZE_MB=50
IMAGE_FORMATS=jpg,jpeg,png,gif,bmp,webp

# 视频配置
VIDEO_MAX_SIZE_MB=500
VIDEO_MAX_DURATION_MINUTES=30
VIDEO_FORMATS=mp4,avi,mov,mkv,flv,wmv

# 音频配置
AUDIO_MAX_SIZE_MB=100
AUDIO_MAX_DURATION_MINUTES=60
AUDIO_FORMATS=mp3,wav,flac,aac,ogg,m4a

# 文本配置
TEXT_MAX_LENGTH=100000

# 模型特定配置
DINO_MODEL_SIZE=base
BERT_MODEL=bert-base-uncased
ROBERTA_MODEL=roberta-base

# 检测配置
CONFIDENCE_THRESHOLD=0.5
BATCH_SIZE=4

# 安全配置
ENABLE_CORS=true
CORS_ORIGINS=*
SECRET_KEY=your-secret-key-here
